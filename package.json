{
    "author": "Adam Boutcher",
    "dependencies": {
        "pebble-clay": "^1.0.4"
    },
    "keywords": [],
    "name": "fuzzy-text-int-l-2",
    "pebble": {
        "capabilities": [
            "configurable"
        ],
        "displayName": "Fuzzy Text International 2",
        "enableMultiJS": true,
        "messageKeys": [
            "INVERT_KEY",
            "TEXT_ALIGN_KEY",
            "LANGUAGE_KEY",
            "FONT_SIZE_KEY",
            "SHOW_DATE_KEY",
            "DATE_TIMEOUT_KEY"
        ],
        "projectType": "native",
        "resources": {
            "media": [
                {
                    "characterRegex": "[A-Za-z0-9\\u00C0-\\u00FF ]",
                    "file": "fonts/large_bold.ttf",
                    "name": "FONT_LARGE_BOLD_50",
                    "type": "font"
                },
                {
                    "characterRegex": "[A-Za-z0-9\\u00C0-\\u00FF ]",
                    "file": "fonts/large_light.ttf",
                    "name": "FONT_LARGE_LIGHT_50",
                    "type": "font"
                }
            ]
        },
        "sdkVersion": "3",
        "targetPlatforms": [
            "aplite",
            "basalt",
            "chalk",
            "diorite",
            "emery",
            "gabbro",
            "flint"
        ],
        "uuid": "88b9a785-1c45-4a56-837f-8c202e4f15bd",
        "watchapp": {
            "watchface": true
        }
    },
    "version": "2.1.3"
}
